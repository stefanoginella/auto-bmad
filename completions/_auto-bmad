#compdef auto-bmad
# zsh completion for auto-bmad
# Install: copy to a directory in $fpath, or source directly
# NOTE: Keep in sync with auto-bmad, auto-bmad-story, auto-bmad-epic parsers

_auto-bmad() {
    local -a commands
    commands=(
        'story:Run the story pipeline (one story at a time)'
        'epic:Run the epic pipeline (all stories in an epic)'
        'status:Show current pipeline state at a glance'
        'quickstart:First-run setup wizard — check tools and readiness'
        'validate:Validate sprint-status.yaml structure and content'
        'config:Show resolved configuration (pipeline.conf + profiles)'
        'help:Show help message'
        'version:Print version info'
    )

    local -a reviews_values
    reviews_values=(full fast none)

    local -a step_ids
    step_ids=(0.1 1.1 1.2 1.3 1.4 2.1 2.2 3.1 3.2 3.3 3.4 3.4b 3.5 4.1 4.2 5.1 5.2 5.3 5.4 5.5 5.6 6.0 6.1 6.2)

    _arguments -C \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'auto-bmad command' commands
            ;;
        args)
            case ${words[1]} in
                story)
                    _arguments \
                        '--story[Override auto-detection]:story_id:' \
                        '--from-step[Resume from step ID]:step_id:(${step_ids})' \
                        '--dry-run[Preview all steps without executing]' \
                        '--skip-cache[Bypass pre-flight cache]' \
                        '--skip-tea[Skip TEA phases]' \
                        '--reviews[Review mode]:mode:(full fast none)' \
                        '--skip-git[Skip git write operations]' \
                        '--no-traces[Remove pipeline artifacts after finalization]' \
                        '--debug[Keep temp files for debugging]' \
                        '--help[Show help]'
                    ;;
                epic)
                    _arguments \
                        '--epic[Target epic number]:epic_id:' \
                        '--from-story[Resume from story]:story_id:' \
                        '--to-story[Stop after story]:story_id:' \
                        '--dry-run[Preview the full epic plan]' \
                        '--no-merge[Skip auto-PR/merge between stories]' \
                        '--skip-cache[Bypass pre-flight cache]' \
                        '--skip-tea[Skip TEA phases]' \
                        '--reviews[Review mode]:mode:(full fast none)' \
                        '--skip-git[Skip git write operations]' \
                        '--no-traces[Remove pipeline artifacts after finalization]' \
                        '--help[Show help]'
                    ;;
            esac
            ;;
    esac
}

_auto-bmad "$@"
